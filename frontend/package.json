{
  "name": "compari-frontend",
  "version": "0.9.0",
  "private": true,
  "description": "Next.js frontend for Compari",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "prestart": "node -e \"if(!require('fs').existsSync('.next/BUILD_ID')) process.exit(1)\" || npm run build",
    "start": "NODE_OPTIONS='--no-warnings' next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/postcss": "^4.2.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "typescript": "^6.0.3"
  }
}
