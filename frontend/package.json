{
  "name": "compari-frontend",
  "version": "0.7.1",
  "private": true,
  "description": "Next.js frontend for Compari",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "prestart": "node -e \"if(!require('fs').existsSync('.next/BUILD_ID')) process.exit(1)\" || npm run build",
    "start": "NODE_OPTIONS='--no-warnings' next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-popover": "^1.1.15",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.7.3"
